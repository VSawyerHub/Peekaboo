{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Peekaboo",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "globalShortcut": { "all": true },
      "window": { "all": true },
      "shell": { "open": true }
    },
    "bundle": {
      "active": true,
      "category": "Utility",
      "copyright": "MIT",
      "deb": { "depends": [] },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "dev.peekaboo.app",
      "longDescription": "Interactive scare overlay for streamers",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [],
      "shortDescription": "Peekaboo streamer overlay",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": { "csp": null },
    "systemTray": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    },
    "updater": { "active": false },
    "windows": [
      {
        "label": "dashboard",
        "title": "Peekaboo",
        "width": 420,
        "height": 680,
        "resizable": false,
        "fullscreen": false,
        "transparent": false,
        "decorations": true,
        "alwaysOnTop": false,
        "url": "index.html"
      },
      {
        "label": "overlay",
        "title": "Peekaboo Overlay",
        "width": 1920,
        "height": 1080,
        "resizable": false,
        "fullscreen": true,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "url": "overlay.html"
      }
    ]
  }
}

{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "vite",
    "beforeBuildCommand": "vite build",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Peekaboo",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "globalShortcut": { "all": true },
      "window": { "all": true },
      "shell": { "open": true }
    },
    "bundle": {
      "active": true,
      "category": "Utility",
      "copyright": "MIT",
      "deb": { "depends": [] },
      "externalBin": [],
      "icon": [],
      "identifier": "dev.peekaboo.app",
      "longDescription": "Interactive scare overlay for streamers",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [],
      "shortDescription": "Peekaboo streamer overlay",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": { "csp": null },
    "systemTray": {
      "iconPath": "",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    },
    "updater": { "active": false },
    "windows": []
  }
}
